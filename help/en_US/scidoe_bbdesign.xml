  <refnamediv>
    <refname>scidoe_bbdesign</refname><refpurpose></refpurpose>
  </refnamediv>



<refsynopsisdiv>
   <title>Calling Sequence</title>
   <synopsis>
   H = scidoe_bbdesign(nbvar)
   H = scidoe_bbdesign(nbvar,nbcenter)
   
   </synopsis>
</refsynopsisdiv>

<refsection>
   <title>Parameters</title>
   <variablelist>
   <varlistentry><term>nbvar :</term>
      <listitem><para> a 1-by-1 matrix of doubles, integer value, nbvar &gt; 2. The number of variables of the experiment</para></listitem></varlistentry>
   <varlistentry><term>nbcenter :</term>
      <listitem><para> a 1-by-1 matrix of doubles, integer value, positive. The number of repetitions of the central point in the design (default nbcenter=1).</para></listitem></varlistentry>
   <varlistentry><term>H :</term>
      <listitem><para> a m-by-nbvar matrix of doubles, the design of experiments, where m=nbvar*4+nbcenter</para></listitem></varlistentry>
   </variablelist>
</refsection>

<refsection>
   <title>Examples</title>
   <programlisting role="example"><![CDATA[
// Create a Box-Benkhen Design with three
// variables one repetition of center:
H = scidoe_bbdesign(3);

// With three variables and the
// center repeated two times:
H = scidoe_bbdesign(3,2);

   ]]></programlisting>
</refsection>

