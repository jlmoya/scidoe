  <refnamediv>
    <refname>scidoe_plotlhs</refname>
    <refpurpose>Plot a LHS design</refpurpose>
  </refnamediv>


<refsynopsisdiv>
   <title>Calling Sequence</title>
   <synopsis>
   scidoe_plotlhs(H)
   
   </synopsis>
</refsynopsisdiv>

<refsection>
   <title>Parameters</title>
   <variablelist>
   <varlistentry><term>H :</term>
      <listitem><para> a n-by-2 or n-by-3 matrix of doubles, the LHS sampling</para></listitem></varlistentry>
   </variablelist>
</refsection>

<refsection>
   <title>Description</title>
   <para>
Plots a 2D or 3D Latin Hypercube Sampling.
   </para>
   <para>
</para>
</refsection>

<refsection>
   <title>Examples</title>
   <programlisting role="example"><![CDATA[
// 2D
H = scidoe_lhsdesign(2,5);
scf();
scidoe_plotlhs(H)
xtitle("LHS design","X1","X2")
// Add labels:
xstring(H(:,1),H(:,2),string(1:5));

// 3D
H = scidoe_lhsdesign(3,5);
scf();
scidoe_plotlhs(H)
xtitle("LHS design","X1","X2")

   ]]></programlisting>
</refsection>

