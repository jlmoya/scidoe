// Test with one parameter
B_comp = scidoe_ccdesign(2);
//
B_exp = [-1.000000 -1.000000
          1.000000 -1.000000
         -1.000000  1.000000
          1.000000  1.000000
          0.000000  0.000000
          0.000000  0.000000
          0.000000  0.000000
          0.000000  0.000000
         -1.414214  0.000000
          1.414214  0.000000
          0.000000 -1.414214
          0.000000  1.414214
          0.000000  0.000000
          0.000000  0.000000
          0.000000  0.000000
          0.000000  0.000000
          ];
B_comp=scidoe_sortdesign(B_comp);
B_exp=scidoe_sortdesign(B_exp);
assert_checkalmostequal(B_exp,B_comp,1.e-4)
 ans  =
 
  T  
