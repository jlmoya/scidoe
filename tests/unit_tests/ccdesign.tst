// <-- JVM NOT MANDATORY -->
//
// The expected designs are generated with 
// the ccd function of the "rsm" package of R
//
// 
// Test with one parameter
C = scidoe_ccdesign(2);
//
B = [-1.000000 -1.000000
     1.000000 -1.000000
     -1.000000  1.000000
     1.000000  1.000000
     0.000000  0.000000
     0.000000  0.000000
     0.000000  0.000000
     0.000000  0.000000
     -1.414214  0.000000
     1.414214  0.000000
     0.000000 -1.414214
     0.000000  1.414214
     0.000000  0.000000
     0.000000  0.000000
     0.000000  0.000000
     0.000000  0.000000];
     
B = scidoe_sortdesign(B);
C = scidoe_sortdesign(C);
assert_checkalmostequal(B,C,1.e-4)
//
